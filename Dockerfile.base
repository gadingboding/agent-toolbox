FROM debian:trixie-slim

ARG DEBIAN_FRONTEND=noninteractive
ARG http_proxy
ARG https_proxy
ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG USE_MIRROR
ARG BUN_VERSION
ARG UV_VERSION
ARG PNPM_VERSION

ENV BUN_INSTALL=/usr/local/bun
ENV COREPACK_HOME=/usr/local/share/corepack
ENV COREPACK_DEFAULT_TO_LATEST=0
ENV PATH=/usr/local/bun/bin:/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin

SHELL ["/bin/bash", "-lc"]

COPY docker/ /tmp/docker-config/

RUN : "${USE_MIRROR:?USE_MIRROR build arg is required}" \
    && : "${BUN_VERSION:?BUN_VERSION build arg is required}" \
    && : "${UV_VERSION:?UV_VERSION build arg is required}" \
    && : "${PNPM_VERSION:?PNPM_VERSION build arg is required}"

RUN HTTP_PROXY_EFF="${http_proxy:-$HTTP_PROXY}" \
    && HTTPS_PROXY_EFF="${https_proxy:-$HTTPS_PROXY}" \
    && if [ -n "${HTTP_PROXY_EFF}" ]; then printf 'Acquire::http::Proxy "%s";\n' "${HTTP_PROXY_EFF}" > /etc/apt/apt.conf.d/99proxy; fi \
    && if [ -n "${HTTPS_PROXY_EFF}" ]; then printf 'Acquire::https::Proxy "%s";\n' "${HTTPS_PROXY_EFF}" >> /etc/apt/apt.conf.d/99proxy; fi \
    && if [ "${USE_MIRROR}" = "1" ]; then install -m 0644 /tmp/docker-config/debian.sources.tuna /etc/apt/sources.list.d/debian.sources; fi

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        bubblewrap \
        ca-certificates \
        cargo \
        cmake \
        curl \
        g++ \
        git \
        libatomic1 \
        node-corepack \
        nodejs \
        procps \
        python3-pip \
        sudo \
        tmux \
        unzip \
        vim \
        xz-utils \
    && rm -rf /var/lib/apt/lists/*

RUN if [ "${USE_MIRROR}" = "1" ]; then \
        mkdir -p /etc/uv; \
        install -m 0644 /tmp/docker-config/pip.conf /etc/pip.conf; \
        install -m 0644 /tmp/docker-config/uv.toml /etc/uv/uv.toml; \
    fi

RUN mkdir -p "${COREPACK_HOME}" \
    && if [ "${USE_MIRROR}" = "1" ]; then export COREPACK_NPM_REGISTRY="https://registry.npmmirror.com"; fi \
    && corepack enable \
    && corepack install -g "pnpm@${PNPM_VERSION}" \
    && pnpm --version

RUN mkdir -p "${BUN_INSTALL}" \
    && curl -fsSL https://bun.sh/install | bash -s -- "bun-v${BUN_VERSION}" \
    && test -x "${BUN_INSTALL}/bin/bun" \
    && "${BUN_INSTALL}/bin/bun" --version

RUN curl -LsSf "https://astral.sh/uv/${UV_VERSION}/install.sh" \
    | env UV_UNMANAGED_INSTALL="/usr/local/bin" sh \
    && chmod +x /usr/local/bin/uv /usr/local/bin/uvx \
    && uv --version

RUN mkdir -p /etc/profile.d \
    && install -m 0644 /tmp/docker-config/tooling.sh /etc/profile.d/tooling.sh \
    && rm -rf /tmp/docker-config

ENV BUN_VERSION=${BUN_VERSION}
ENV UV_VERSION=${UV_VERSION}
ENV PNPM_VERSION=${PNPM_VERSION}

CMD ["/bin/bash"]
